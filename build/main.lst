  37:Core/Src/main.c **** 
  38:Core/Src/main.c **** uint16_t adc_value = 0;
  39:Core/Src/main.c **** uint16_t audio_center = 2048;
  40:Core/Src/main.c **** uint16_t amplitude = 0;
  41:Core/Src/main.c **** 
  42:Core/Src/main.c **** uint8_t led_level = 0;
  43:Core/Src/main.c **** uint8_t displayed_level = 0;
  44:Core/Src/main.c **** 
  45:Core/Src/main.c **** uint32_t hold_time = 1000;
  46:Core/Src/main.c **** uint32_t last_peak_time = 0;
  47:Core/Src/main.c **** 
  48:Core/Src/main.c **** int main(void)
  49:Core/Src/main.c **** {
  50:Core/Src/main.c ****     HAL_Init();
  51:Core/Src/main.c **** 
  52:Core/Src/main.c ****     SystemClock_Config();
  53:Core/Src/main.c **** 
  54:Core/Src/main.c ****     MX_GPIO_Init();
  55:Core/Src/main.c ****     MX_ADC1_Init();
  56:Core/Src/main.c ****     MX_USART1_UART_Init();
  57:Core/Src/main.c **** 
  58:Core/Src/main.c ****     for (uint8_t k = 0; k < 3; k++)
  59:Core/Src/main.c ****     {
  60:Core/Src/main.c ****         for (uint8_t i = 0; i < NUM_LEDS; i++)
  61:Core/Src/main.c ****         {
  62:Core/Src/main.c ****             HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_SET);
  63:Core/Src/main.c ****         }
  64:Core/Src/main.c **** 
  65:Core/Src/main.c ****         HAL_Delay(300);
  66:Core/Src/main.c **** 
  67:Core/Src/main.c ****         for (uint8_t i = 0; i < NUM_LEDS; i++)
  68:Core/Src/main.c ****         {
  69:Core/Src/main.c ****             HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_RESET);
  70:Core/Src/main.c ****         }
  71:Core/Src/main.c **** 
  72:Core/Src/main.c ****         HAL_Delay(300);
  73:Core/Src/main.c ****     }
  74:Core/Src/main.c **** 
  75:Core/Src/main.c ****     while (1)
  76:Core/Src/main.c ****     {
  77:Core/Src/main.c ****         adc_value = Read_ADC();
  78:Core/Src/main.c **** 
  79:Core/Src/main.c ****         if (adc_value > audio_center)
  80:Core/Src/main.c ****         {
  81:Core/Src/main.c ****             amplitude = adc_value - audio_center;
  82:Core/Src/main.c ****         }
  83:Core/Src/main.c ****         else
  84:Core/Src/main.c ****         {
  85:Core/Src/main.c ****             amplitude = audio_center - adc_value;
  86:Core/Src/main.c ****         }
  87:Core/Src/main.c **** 
  88:Core/Src/main.c ****         led_level = (amplitude * NUM_LEDS) / 700;
  89:Core/Src/main.c **** 
  90:Core/Src/main.c ****         if (led_level > NUM_LEDS)
ARM GAS  C:\Users\Stanciu\AppData\Local\Temp\ccslQZgf.s 			page 3


  91:Core/Src/main.c ****         {
  92:Core/Src/main.c ****             led_level = NUM_LEDS;
  93:Core/Src/main.c ****         }
  94:Core/Src/main.c **** 
  95:Core/Src/main.c ****         if (led_level > displayed_level)
  96:Core/Src/main.c ****         {
  97:Core/Src/main.c ****             displayed_level = led_level;
  98:Core/Src/main.c ****             last_peak_time = HAL_GetTick();
  99:Core/Src/main.c ****         }
 100:Core/Src/main.c **** 
 101:Core/Src/main.c ****         if ((HAL_GetTick() - last_peak_time) > hold_time)
 102:Core/Src/main.c ****         {
 103:Core/Src/main.c ****             displayed_level = led_level;
 104:Core/Src/main.c ****         }
 105:Core/Src/main.c **** 
 106:Core/Src/main.c ****         for (uint8_t i = 0; i < NUM_LEDS; i++)
 107:Core/Src/main.c ****         {
 108:Core/Src/main.c ****             if (i < displayed_level)
 109:Core/Src/main.c ****             {
 110:Core/Src/main.c ****                 HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_SET);
 111:Core/Src/main.c ****             }
 112:Core/Src/main.c ****             else
 113:Core/Src/main.c ****             {
 114:Core/Src/main.c ****                 HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_RESET);
 115:Core/Src/main.c ****             }
 116:Core/Src/main.c ****         }
 117:Core/Src/main.c **** 
 118:Core/Src/main.c ****         HAL_Delay(10);
 119:Core/Src/main.c ****     }
 120:Core/Src/main.c **** }
