  27:Core/Src/main.c **** };
  28:Core/Src/main.c **** 
  29:Core/Src/main.c **** uint16_t adc_value = 0;
  30:Core/Src/main.c **** uint16_t audio_center = 2048;
  31:Core/Src/main.c **** uint16_t amplitude = 0;
  32:Core/Src/main.c **** 
  33:Core/Src/main.c **** uint8_t led_level = 0;
ARM GAS  C:\Users\Stanciu\AppData\Local\Temp\ccQEfv7K.s 			page 2


  34:Core/Src/main.c **** uint8_t peak_level = 0;
  35:Core/Src/main.c **** 
  36:Core/Src/main.c **** uint32_t hold_time = 1000;
  37:Core/Src/main.c **** uint32_t last_peak_time = 0;
  38:Core/Src/main.c **** 
  39:Core/Src/main.c **** int main(void)
  40:Core/Src/main.c **** {
  41:Core/Src/main.c ****     HAL_Init();
  42:Core/Src/main.c **** 
  43:Core/Src/main.c ****     SystemClock_Config();
  44:Core/Src/main.c **** 
  45:Core/Src/main.c ****     MX_GPIO_Init();
  46:Core/Src/main.c ****     MX_ADC1_Init();
  47:Core/Src/main.c ****     MX_USART1_UART_Init();
  48:Core/Src/main.c **** 
  49:Core/Src/main.c ****     for (uint8_t k = 0; k < 3; k++)
  50:Core/Src/main.c ****     {
  51:Core/Src/main.c ****         for (uint8_t i = 0; i < NUM_LEDS; i++)
  52:Core/Src/main.c ****         {
  53:Core/Src/main.c ****             HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_SET);
  54:Core/Src/main.c ****         }
  55:Core/Src/main.c **** 
  56:Core/Src/main.c ****         HAL_Delay(300);
  57:Core/Src/main.c **** 
  58:Core/Src/main.c ****         for (uint8_t i = 0; i < NUM_LEDS; i++)
  59:Core/Src/main.c ****         {
  60:Core/Src/main.c ****             HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_RESET);
  61:Core/Src/main.c ****         }
  62:Core/Src/main.c **** 
  63:Core/Src/main.c ****         HAL_Delay(300);
  64:Core/Src/main.c ****     }
  65:Core/Src/main.c **** 
  66:Core/Src/main.c ****     while (1)
  67:Core/Src/main.c ****     {
  68:Core/Src/main.c ****         adc_value = Read_ADC();
  69:Core/Src/main.c **** 
  70:Core/Src/main.c ****         if (adc_value > audio_center)
  71:Core/Src/main.c ****         {
  72:Core/Src/main.c ****             amplitude = adc_value - audio_center;
  73:Core/Src/main.c ****         }
  74:Core/Src/main.c ****         else
  75:Core/Src/main.c ****         {
  76:Core/Src/main.c ****             amplitude = audio_center - adc_value;
  77:Core/Src/main.c ****         }
  78:Core/Src/main.c **** 
  79:Core/Src/main.c ****         led_level = (amplitude * NUM_LEDS) / 700;
  80:Core/Src/main.c **** 
  81:Core/Src/main.c ****         if (led_level > NUM_LEDS)
  82:Core/Src/main.c ****         {
  83:Core/Src/main.c ****             led_level = NUM_LEDS;
  84:Core/Src/main.c ****         }
  85:Core/Src/main.c **** 
  86:Core/Src/main.c ****         if (led_level > peak_level)
  87:Core/Src/main.c ****         {
  88:Core/Src/main.c ****             peak_level = led_level;
  89:Core/Src/main.c ****             last_peak_time = HAL_GetTick();
  90:Core/Src/main.c ****         }
ARM GAS  C:\Users\Stanciu\AppData\Local\Temp\ccQEfv7K.s 			page 3


  91:Core/Src/main.c **** 
  92:Core/Src/main.c ****         if ((HAL_GetTick() - last_peak_time) > hold_time)
  93:Core/Src/main.c ****         {
  94:Core/Src/main.c ****             peak_level = led_level;
  95:Core/Src/main.c ****             last_peak_time = HAL_GetTick();
  96:Core/Src/main.c ****         }
  97:Core/Src/main.c **** 
  98:Core/Src/main.c ****         for (uint8_t i = 0; i < NUM_LEDS; i++)
  99:Core/Src/main.c ****         {
 100:Core/Src/main.c ****             if ((i < led_level) || (peak_level > 0 && i == peak_level-1))
 101:Core/Src/main.c ****             {
 102:Core/Src/main.c ****                 HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_SET);
 103:Core/Src/main.c ****             }
 104:Core/Src/main.c ****             else
 105:Core/Src/main.c ****             {
 106:Core/Src/main.c ****                 HAL_GPIO_WritePin(ports[i], pins[i], GPIO_PIN_RESET);
 107:Core/Src/main.c ****             }
 108:Core/Src/main.c ****         }
 109:Core/Src/main.c **** 
 110:Core/Src/main.c ****         HAL_Delay(10);
 111:Core/Src/main.c ****     }
